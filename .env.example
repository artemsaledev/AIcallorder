APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/loom_automation.db

LOOM_EMAIL=
LOOM_PASSWORD=
LOOM_WORKSPACE_ID=
LOOM_LIBRARY_URL=https://www.loom.com/looms/videos
LOOM_TRANSCRIPT_SOURCE=meeting_ai
LOOM_USE_SELENIUM_FALLBACK=false
# Linux production uses a persistent non-headless Chromium profile under Xvfb.
# Complete Loom / Atlassian email verification or 2FA once in that same profile.
LOOM_HEADLESS=false
# Example tested VPS values:
# CHROME_BINARY=/usr/bin/chromium-browser
# CHROMEDRIVER_PATH=/snap/bin/chromium.chromedriver
# CHROME_USER_DATA_DIR=/home/deploy/snap/chromium/common/aicallorder-profile
CHROME_BINARY=
CHROMEDRIVER_PATH=
CHROME_USER_DATA_DIR=
CHROME_WINDOW_SIZE=1600,1200
CHROME_EXTRA_ARGS=
COLLECTOR_SOURCE=loom
LOCAL_VIDEO_FOLDER=
LOOM_TITLE_INCLUDE_KEYWORDS=
LOOM_TITLE_EXCLUDE_KEYWORDS=
PROMPT_ROUTES_PATH=promts/prompt_routes.json
TRANSCRIPT_PREPROCESS_ENABLED=true
DEFAULT_TRANSCRIPT_PROMPT_PATH=promts/promts_transcription.txt

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

LLM_PROVIDER=auto
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120

LOCAL_LLM_COMMAND=C:\path\to\run_local_llm.cmd
LOCAL_LLM_MODEL_PATH=
LOCAL_WHISPER_COMMAND=
LOCAL_WHISPER_MODEL=medium
PREFER_LOCAL_WHISPER_FOR_LOCAL_FILES=true

GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DOCS_FOLDER_ID=
GOOGLE_DOC_ID=
GOOGLE_TRANSCRIPT_DOC_ID=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_WORKSHEET=Transcript

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

WEBHOOK_SHARED_SECRET=

SCHEDULER_ENABLED=false
SCHEDULER_MEETING_TYPE=discord-sync
SCHEDULER_LOCAL_FOLDER_ENABLED=false
SCHEDULER_LOCAL_FOLDER_MINUTES=30
SCHEDULER_LOOM_ENABLED=false
SCHEDULER_LOOM_MINUTES=30
SCHEDULER_LOOM_LIMIT=3
SCHEDULER_ACTIVE_FROM=08:00
SCHEDULER_ACTIVE_TO=21:00
SCHEDULER_ACTIVE_WEEKDAYS=mon,tue,wed,thu,fri
